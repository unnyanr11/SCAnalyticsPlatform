# Copy to .env and fill in real values before running.
# Never commit .env to version control.

DEBUG=true

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_generate_a_real_secret_here

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=scanalytics
POSTGRES_USER=scanalytics
POSTGRES_PASSWORD=CHANGE_ME

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# CORS (comma-separated)
CORS_ORIGINS=chrome-extension://*,http://localhost:3000

# AI
AI_PREDICTION_TTL_SECONDS=300
MARKET_HISTORY_LIMIT=60
