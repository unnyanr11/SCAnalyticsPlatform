# SC Analytics Platform — Backend Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the real .env file.

# ─── App ────────────────────────────────────────────────────────────
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=change-this-to-a-long-random-secret
APP_ALLOWED_ORIGINS=chrome-extension://your-extension-id,http://localhost:5173

# ─── PostgreSQL ──────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=sc_analytics
POSTGRES_USER=sc_user
POSTGRES_PASSWORD=change-this-password
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ─── Redis ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL_SECONDS=60

# ─── Data Sources ─────────────────────────────────────────────────────────
SIMCO_API_BASE=https://www.simcompanies.com
SIMCOTOOLS_API_BASE=https://simcotools.app
SIMCOTOOLS_ALT_API_BASE=https://api.simcotools.com
SIMCO_REALM=0

# ─── Rate Limiting ──────────────────────────────────────────────────────────
MAX_REQUESTS_PER_MINUTE=30

# ─── Optional Notifications ───────────────────────────────────────────────
DISCORD_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
